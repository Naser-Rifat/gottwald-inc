# Public site URL (used for sitemap, OG tags, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://gottwald.world

# Controls where data comes from
# "mock"  → uses local mock data (right now)
# "api"   → calls the real backend (when backend is ready)
NEXT_PUBLIC_DATA_SOURCE=mock

# Backend API base URL — fill this in when backend is ready
NEXT_PUBLIC_API_URL=http://3.124.12.80:8000

# Read-only API key for server-side pillar fetches (if backend requires auth).
# Or configure backend to allow unauthenticated GET on /api/v1/pillars/
API_READ_KEY=

# Shared secret for the cache-invalidation webhook from Django.
# Django's pillar/signals.py POSTs to /api/revalidate with this Bearer token
# after every pillar save. Must match REVALIDATE_SECRET in gottwald-backend/.env.
REVALIDATION_SECRET=cafcdcbce224ad3b977cbefd954a2c94d2e7effc33da8edbea207f35f1458709

# ─── EMAIL SENDER (RESEND) ───
RESEND_API_KEY="re_GYndV4De_84iFFCTzVdtggXi9zZJfUKbR"
RESEND_FROM="dev.abuanserrifat@gmail.com"
RESEND_TO="dev.abuanserrifat@gmail.com"
