# # Public site URL (used for sitemap, OG tags, canonical URLs)
# NEXT_PUBLIC_SITE_URL=https://gottwald.world

# # Controls where data comes from
# # "mock"  → uses local mock data (right now)
# # "api"   → calls the real backend (when backend is ready)
# NEXT_PUBLIC_DATA_SOURCE=mock

# # Backend API base URL — fill this in when backend is ready
# NEXT_PUBLIC_API_URL=https://gottwald-backend.onrender.com/

# # Read-only API key for server-side pillar fetches (if backend requires auth).
# API_READ_KEY=

# # ─── EMAIL SENDER (RESEND) ───
# # See Resend dashboard for your API key
# RESEND_API_KEY=""
# RESEND_FROM="no-reply@gottwald.world"
# RESEND_TO="office@gottwald.world"
