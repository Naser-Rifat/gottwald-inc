# # Public site URL (used for sitemap, OG tags, canonical URLs)
# NEXT_PUBLIC_SITE_URL=https://gottwald.world

# # Controls where data comes from
# # "mock"  → uses local mock data (right now)
# # "api"   → calls the real backend (when backend is ready)
# NEXT_PUBLIC_DATA_SOURCE=mock

# # Backend API base URL — fill this in when backend is ready
# NEXT_PUBLIC_API_URL=https://gottwald-admin.vercel.app/

# # Read-only API key for server-side pillar fetches (if backend requires auth).
# API_READ_KEY=

# # ─── EMAIL SENDER (RESEND) ───
# # See Resend dashboard for your API key
# RESEND_API_KEY=""
# RESEND_FROM="no-reply@gottwald.world"
# RESEND_TO="office@gottwald.world"

# # ─── SOCIAL PROFILES (SEO / GEO sameAs schema) ───
# # Each URL is emitted as `sameAs` in the Organization JSON-LD so that AI
# # search engines (ChatGPT, Perplexity, Claude, Gemini) and Google's Knowledge
# # Panel can link the GOTT WALD entity to its public profiles. Leave blank to
# # omit — no need to delete the line. YouTube is hardcoded in lib/seo.ts.
# NEXT_PUBLIC_SOCIAL_LINKEDIN=https://www.linkedin.com/company/<slug>
# NEXT_PUBLIC_SOCIAL_CRUNCHBASE=https://www.crunchbase.com/organization/<slug>
# NEXT_PUBLIC_SOCIAL_X=https://x.com/<handle>
# NEXT_PUBLIC_SOCIAL_WIKIDATA=https://www.wikidata.org/wiki/<Q-id>
# NEXT_PUBLIC_SOCIAL_FACEBOOK=https://www.facebook.com/<page>
# NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://www.instagram.com/<handle>
# NEXT_PUBLIC_SOCIAL_GITHUB=https://github.com/<org>

# # ─── ERROR MONITORING (SENTRY) ───
# # Public DSN — safe to ship to the browser. Without it, Sentry SDK no-ops.
# NEXT_PUBLIC_SENTRY_DSN=
# # Optional server-only DSN (defaults to the public one if not set).
# SENTRY_DSN=
# # Build-time only — used to upload source maps. Set in Vercel project env,
# # NOT in this committed file. Without it, source map upload is skipped but
# # runtime error capture still works.
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=
